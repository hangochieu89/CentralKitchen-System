{
  "info": {
    "name": "Central Kitchen - Supply Coordinator API",
    "description": "Collection of API endpoints for Supply Coordinator module",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "📋 Order Management",
      "item": [
        {
          "name": "1.1 Get All Pending Orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/orders/pending",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "orders", "pending"]
            },
            "description": "Lấy tất cả đơn hàng chờ xử lý (status = PENDING)"
          },
          "response": []
        },
        {
          "name": "1.2 Get Orders by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/orders/status/PENDING",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "orders", "status", "PENDING"]
            },
            "description": "Lấy đơn hàng theo trạng thái cụ thể"
          },
          "response": []
        },
        {
          "name": "1.3 Get Orders by Date Range",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/orders/date-range?startDate=2024-04-01T00:00:00&endDate=2024-04-30T23:59:59",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "orders", "date-range"],
              "query": [
                {
                  "key": "startDate",
                  "value": "2024-04-01T00:00:00"
                },
                {
                  "key": "endDate",
                  "value": "2024-04-30T23:59:59"
                }
              ]
            },
            "description": "Lấy đơn hàng trong khoảng thời gian"
          },
          "response": []
        },
        {
          "name": "1.4 Get Orders by Store",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/orders/store/2",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "orders", "store", "2"]
            },
            "description": "Lấy đơn hàng của một cửa hàng cụ thể"
          },
          "response": []
        },
        {
          "name": "1.5 Confirm Order",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/orders/1/confirm",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "orders", "1", "confirm"]
            },
            "description": "Xác nhận đơn hàng (PENDING → CONFIRMED)"
          },
          "response": []
        }
      ]
    },
    {
