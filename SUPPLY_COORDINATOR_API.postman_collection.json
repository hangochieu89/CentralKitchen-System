          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": 3,\n  \"coordinatorId\": 3,\n  \"scheduledAt\": \"2024-04-15T08:30:00\",\n  \"note\": \"Giao sáng, cần xác nhận trước\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/deliveries/schedule",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "deliveries", "schedule"]
