            "description": "Lấy tất cả giao hàng của một coordinator"
          },
          "response": []
        },
        {
          "name": "2.4 Get Deliveries by Status",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/deliveries/status/DELIVERED",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "deliveries", "status", "DELIVERED"]
