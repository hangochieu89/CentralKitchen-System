            "description": "Lấy giao hàng theo trạng thái"
          },
          "response": []
        },
        {
          "name": "2.5 Get Overdue Deliveries",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/deliveries/overdue",
              "host": ["{{base_url}}"],
              "path": ["api", "supply-coordinator", "deliveries", "overdue"]
