              "raw": "{\n  \"deliveryId\": 1,\n  \"status\": \"DELIVERED\",\n  \"actualAt\": \"2024-04-15T08:45:00\",\n  \"note\": \"Giao thành công, khách đã ký nhận\"\n}"
            },
            "url": {
              "raw": "{{base_url}}/api/supply-coordinator/deliveries/update-status",
